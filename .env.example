# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Required. Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_api_key_here
# ─── LinkedIn / Proxycurl (optional — only needed for real LinkedIn scraping) ─
# Leave blank to use the 'mock' platform instead.
# Get your key at: https://nubela.co/proxycurl
LINKEDIN_API_URL=
LINKEDIN_API_KEY=
