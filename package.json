{
  "name": "agentsforhr",
  "version": "1.0.0",
  "description": "Production-grade Multi-Agent AI system for HR automation — built with Node.js, TypeScript, Express, and LangChain.",
  "author": "",
  "license": "ISC",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon",
    "dev:ui": "cd frontend && npm run dev",
    "build": "npm run build --prefix frontend && tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "echo \"No tests configured yet. Add Jest or Vitest here.\" && exit 0"
  },
  "keywords": [
    "typescript",
    "express",
    "langchain",
    "multi-agent",
    "ai",
    "hr-automation",
    "clean-architecture"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@langchain/core": "^1.1.48",
    "@types/pdf-parse": "^1.1.5",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "imapflow": "^1.3.4",
    "langchain": "^1.4.2",
    "mailparser": "^3.9.9",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.9.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
